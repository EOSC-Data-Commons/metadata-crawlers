        <titleInfo lang="eng" usage="primary">
          <title>Fast clustering in linear independent 1D subspaces: segmentation of multi-channel images with high spatial resolution</title>
        </titleInfo>
        <language>
          <languageTerm type="code" authority="iso639-2b">eng</languageTerm>
        </language>
